# Azure OpenAI Configuration — Whisper (transcription)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=whisper
AZURE_OPENAI_API_VERSION=2024-06-01

# (Optional) GPT deployment for lyrics polish — leave blank to disable
# Can be on the SAME resource (leave GPT_API_KEY blank to reuse Whisper key)
# or a DIFFERENT resource (provide its own key + endpoint)
AZURE_OPENAI_GPT_DEPLOYMENT=
AZURE_OPENAI_GPT_API_KEY=
AZURE_OPENAI_GPT_ENDPOINT=
AZURE_OPENAI_GPT_API_VERSION=2024-06-01